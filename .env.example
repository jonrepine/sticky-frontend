VITE_API_URL=http://localhost:4000
# Production builds can override via .env.production or host env:
# VITE_API_URL=https://sticky-backend-production.up.railway.app
#
# Optional: set when LLM endpoints are hosted outside this frontend runtime.
# If unset, frontend calls local /api/llm/* (works with Vite dev proxy only).
# VITE_LLM_API_BASE_URL=https://sticky-backend-production.up.railway.app

# Server-side only (used by local LLM proxy in vite.config.ts)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_ALLOW_FALLBACK=false

